{
  "name": "@somenergia/frontend-config",
  "version": "1.0.0",
  "description": "Unified frontend configuration from somenergia",
  "type": "module",
  "exports": {
    "./eslint": {
      "types": "./eslint.d.ts",
      "default": "./eslint.js"
    },
    "./prettier": {
      "types": "./prettier.d.ts",
      "default": "./prettier.js"
    },
    "./vite": {
      "types": "./vite.d.ts",
      "default": "./vite.js"
    }
  },
  "files": [
    "./scripts/todos.sh",
    "eslint.js",
    "eslint.d.ts",
    "prettier.js",
    "prettier.d.ts",
    "vite.js",
    "vite.d.ts"
  ],
  "bin": {
    "todos": "./scripts/todos.sh"
  },
  "dependencies": {
    "@eslint/js": "^9.13.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "license": "MIT"
}
